# IB Gateway / TWS connection
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
DATA_DIR=./data

# If true, strategy runs and signals are logged, but no orders hit IBKR.
DRY_RUN=true

# Symbol is hardcoded in strategy for Phase 0, but surfaced here for visibility.
STRATEGY_SYMBOL=SPY
STRATEGY_QTY=1
